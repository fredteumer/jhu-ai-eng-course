# Module 4 — credential template for LOCAL runs.
# --------------------------------------------------------------------------
# The notebook only needs these when RUN_LIVE = True (live SerpAPI + LLM calls).
# When RUN_LIVE = False (default), it runs fully offline against cached data and
# no keys are required.
#
# USAGE (local):
#   1. Copy this file to `.env`  ->  cp .env.example .env
#   2. Paste your real values into `.env` (which is git-ignored).
#   3. The setup cell auto-loads `.env` via python-dotenv.
#
# In Google Colab, use the Secrets (key) panel instead, with these same names.
# NEVER commit real keys. `.env` is git-ignored; this template is not.
# --------------------------------------------------------------------------

# SerpAPI key for google_flights / google_hotels search
serp_api=your_serpapi_key_here

# Great Learning OpenAI-compatible LLM endpoint key
GL_OpenAI=your_llm_key_here
