# 1. Trigger the security check before anything else happens
auth_request /authelia_verify;

# 2. Define the internal location for Authelia communication
location = /authelia_verify {
    internal;
    
    # Resolver allows Nginx to find the 'authelia' container by its Docker name
    resolver 127.0.0.11 valid=30s;
    
    # Proxy the check to the Authelia API
    proxy_pass http://authelia:9091/api/verify;
    
    # Do not send the request body (POST data) to Authelia, only headers
    proxy_pass_request_body off;
    proxy_set_header Content-Length "";
    
    # Pass critical headers so Authelia knows which site is being accessed
    proxy_set_header X-Original-URL $scheme://$http_host$request_uri;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

# 3. Handle the actual traffic to the Ghost container
location / {
    # REWRITE: If you hit the root (admin.home.local), force redirect to /ghost/
    rewrite ^/$ /ghost/ permanent;

    # Capture the current URL to return here after successful 2FA
    set $target_url $scheme://$http_host$request_uri;
    
    # If Authelia returns a 401 (Unauthorized), redirect to the Auth Portal
    error_page 401 =302 https://auth.home.local/?rd=$target_url;

    # --- Ghost Identity Spoofing ---
    # We tell Ghost it is being reached via its 'official' blog URL
    proxy_set_header Host blog.home.local;
    proxy_set_header X-Forwarded-Host $http_host;

    # Ghost also validates the browser's Origin header against its configured
    # `url` and rejects admin logins that disagree ("Request made from incorrect
    # origin"). The Host spoof above is not sufficient on current Ghost versions,
    # so rewrite Origin to match as well.
    proxy_set_header Origin https://blog.home.local;
    
    # Standard Proxy Headers
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Send the final authorized request to the Ghost container
    proxy_pass http://ghost:2368;
}
