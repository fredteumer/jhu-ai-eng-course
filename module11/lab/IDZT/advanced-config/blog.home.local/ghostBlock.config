# 1. Allow public access to the Ghost API (vital for frontend features)
location ^~ /ghost/api/ {
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_pass http://ghost:2368;
}

# 2. Catch exactly "/ghost" (no trailing slash) and bounce it to the secure domain
location = /ghost {
    return 301 https://admin.home.local/ghost/;
}

# 3. Catch "/ghost/" and all admin subdirectories, bouncing them to the secure domain
location ^~ /ghost/ {
    return 301 https://admin.home.local$request_uri;
}
